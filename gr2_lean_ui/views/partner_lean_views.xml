<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Lean Partner (Customer/Vendor) form for GR2 project:
         - Keep only: Name, Address (Street, City), Phone, Birthdate
         - Hide: All other fields
    -->
    <record id="view_partner_form_lean_ui" model="ir.ui.view">
        <field name="name">res.partner.form.lean.ui</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">

            <!-- Hide Email field -->
            <xpath expr="//field[@name='email']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Mobile field -->
            <xpath expr="//field[@name='mobile']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Website field -->
            <xpath expr="//field[@name='website']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Tax ID (VAT) field -->
            <xpath expr="//field[@name='vat']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Category (Tags) field -->
            <xpath expr="//field[@name='category_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Comment/Notes field -->
            <xpath expr="//field[@name='comment']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Company Name field -->
            <xpath expr="//field[@name='parent_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Job Position field -->
            <xpath expr="//field[@name='function']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Title field -->
            <xpath expr="//field[@name='title']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Language field -->
            <xpath expr="//field[@name='lang']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Street 2 field -->
            <xpath expr="//field[@name='street2']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide ZIP field -->
            <xpath expr="//field[@name='zip']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide State field -->
            <xpath expr="//field[@name='state_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Country field -->
            <xpath expr="//field[@name='country_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Avatar/Image field -->
            <xpath expr="//field[@name='image_1920']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Company Type radio buttons -->
            <xpath expr="//field[@name='company_type']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Is Company checkbox -->
            <xpath expr="//field[@name='is_company']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Add Birthdate field after Phone field -->
            <!-- NOTE: Uncomment this after upgrading module to create the database column -->
            <!--
            <xpath expr="//field[@name='phone']" position="after">
                <field name="birthdate" string="Ngày sinh"/>
            </xpath>
            -->

        </field>
    </record>

</odoo>

